DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=geraxtech

# Origens permitidas para chamar o backend (separar por vírgula).
# Em produção, troque pelos domínios reais. Ex: https://geraxtech.com.br,https://www.geraxtech.com.br
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Token usado para baixar o Excel de contatos via /contatos/exportar?token=...
# GERE UM VALOR LONGO E ALEATÓRIO em produção (ex: openssl rand -hex 32)
EXPORT_TOKEN=mude-este-valor

# Chave da API do Resend (https://resend.com/api-keys)
RESEND_API_KEY=
# Remetente: precisa ser um endereço de um domínio verificado no Resend.
# Para testes rápidos use onboarding@resend.dev
EMAIL_REMETENTE=Contato@geraxtech.com.br
EMAIL_DESTINO=Contato@geraxtech.com.br
